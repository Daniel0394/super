  var textDecoder, readableStreamClosed, reader;
  var navigatorObject = window.navigator;


  async function connect() {

    console.log(navigatorObject);
      // validar si el navegor soporta la API
      if ("serial" in navigator) {

          // seleccionar el puerto
          port = await navigator.serial.requestPort();

          // abrir el puerto
          await port.open({
              baudRate: 9600
          });

          // 
          textEncoder = new TextEncoderStream();
          writableStreamClosed = textEncoder.readable.pipeTo(port.writable);
          writer = textEncoder.writable.getWriter();
          await writer.write("T");

          // Obtener el peso
          textDecoder = new TextDecoderStream();
          readableStreamClosed = port.readable.pipeTo(textDecoder.writable);
          reader = textDecoder.readable.getReader();

          while (true) {
              const { value, done } = await reader.read();
              if (done) {
                  // Allow the serial port to be closed later.
                  console.log(value);

                  reader.releaseLock();
                  break;
              }
              console.log(value);
          }

      } else {
          alert("Tu navegador no soporta la API");
      }



