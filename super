                        return;
                    }

                    // console.log(this.quantity)

                    // this.$wire.set('qtyEndowment', this.quantity)
                    this.quantity = ""
                    this.$wire.changeQuantity(this.saleRowId,quantity)
                    return;
                }

                let character = event.target.innerText;

                this.quantity += character;

            },

            focusTextInput() {
                const textInput = this.$refs.textInput;
