    document.addEventListener('alpine:init', () => {
        Alpine.data('keyboardChangeQuantityFunctions', () => ({
            // write: '',  se lo pasa al contenedor
            quantity: "",

            handleClick(event) {

                const deleteButton = event.target.closest('.delete');
                const checkButton = event.target.closest('.check');

                const punto = event.target.closest('.punto');

                if (punto) {

                    return;
                }

                if (deleteButton) {
                    this.quantity = this.quantity.slice(0, -1);

                    return;
                }

                if (checkButton) {
                    let quantity = parseFloat(this.quantity);

                    if (isNaN(quantity)) {
                            Toastify({
                            text: "Ingrese la cantidad",
                            className: "info",
                            gravity: "top", // `top` or `bottom`
                            position: "center", // `left`, `center` or `right`
