              this.strTotalPositivo  = data.strTotalPositivo
              this.strTotalNegativo  = data.strTotalNegativo
            */

              // this.showFormSalesFunctions = false;
              // this.panelSalesSummary = false;

              // this.showPanelBoxArching = true;                    

              // console.log(data)

            },

            sumCoins() {
                this.moneda.UnoC  = (parseInt(this.unoC) * 1 /100) || 0
                this.moneda.DosC  = (parseInt(this.dosC) * 2 / 100) || 0
                this.moneda.CinC  = (parseInt(this.cincoC) * 5 / 100) || 0
                this.moneda.DieC  = (parseInt(this.diezC) * 10 / 100) || 0
                this.moneda.VeiC  = (parseInt(this.veinteC) * 20 / 100) || 0
                this.moneda.CincC = (parseInt(this.cincueC) * 50 / 100) || 0
                this.moneda.UnE   = (parseInt(this.unE) * 1 ) || 0
                this.moneda.DosE  = (parseInt(this.dosE) * 2) || 0

                const suma = this.moneda.UnoC + this.moneda.DosC + this.moneda.CinC + this.moneda.DieC +this.moneda.VeiC + this.moneda.CincC + this.moneda.UnE + this.moneda.DosE;

                this.totalCoins = suma

                return suma.toLocaleString('es-ES', {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                });
            },

            sumBills() {
                this.billete.cincoE  = (parseInt(this.cincoE) * 5 ) || 0
                this.billete.diezE   = (parseInt(this.diezE) * 10 ) || 0
                this.billete.veinteE = (parseInt(this.veinteE) * 20 ) || 0
                this.billete.cincueE = (parseInt(this.cincueE) * 50 ) || 0
                this.billete.cienE   = (parseInt(this.cienE) * 100 ) || 0
                this.billete.doscE   = (parseInt(this.doscE) * 200 ) || 0

                let totalBilletes = 0;

                for (const key in this.billete) {
                    totalBilletes += (this.billete[key] || 0);
                }

                this.totalBillete = totalBilletes;

                return totalBilletes.toLocaleString('es-ES', {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                });
            },

            diferenciaDatafono(){
                let strDiferencia = ""
                if (this.datafono == ""){
                    strDiferencia = ""
                }else{
                    let diferencia = (parseFloat(this.saleCard) - parseFloat(this.datafono));
                    strDiferencia = diferencia.toLocaleString('es-ES', {
                        minimumFractionDigits: 2,
                        maximumFractionDigits: 2
                    });
                }

               return strDiferencia;  //parseFloat((this.saleCard - this.datafono) || 0)
            },
            totalEnCaja(){

                let grandTotal = this.totalCoins + this.totalBillete;

                /*
                if (this.datafono !== "") {
                    grandTotal += parseFloat(this.datafono);
                    console.log(grandTotal)
                }*/

                this.granTotal = grandTotal

                return grandTotal.toLocaleString('es-ES', {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                });
            },
            diferenciaSistemaConConteoManual(){
                let diferencia = this.granTotal - this.operationsBalance

                if(diferencia > 0){
                  this.showClassDifference = true
                }else{  
                  this.showClassDifference = false
                }  
                return diferencia.toLocaleString('es-ES', {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                });
            },
            changeValueCoins(data){
              // alert("SKSKSK")
                switch (data.input) {
                    case "unoC": this.unoC = data.value
                        break;
                    case "dosC": this.dosC = data.value
                        break;
                    case "cincoC": this.cincoC = data.value
                        break;
                    case "diezC": this.diezC = data.value
                        break;
                    case "veinteC": this.veinteC = data.value
                        break;
                    case "cincueC": this.cincueC = data.value
                        break;
                    case "unE": this.unE = data.value
                        break;
                    case "dosE": this.dosE = data.value
                        break;
                    //billetes
                    case "cincoE": this.cincoE = data.value
                        break;
                    case "diezE": this.diezE = data.value
                        break;
                    case "veinteE": this.veinteE = data.value
                        break;
                    case "cincueE": this.cincueE = data.value
                        break;
                    case "cienE": this.cienE = data.value
                        break;
                    case "doscE": this.doscE = data.value
                        break;

                    case "datafono": this.datafono = data.value
                        break;

                    default:
                        break;
                }

            },

            
            cerrarCaja(){
                console.log("cerrando caja", this.totalEnCaja())

                if (this.totalEnCaja() == '0,00'){
                  Toastify({
                            text: "INCONSISTENCIA:  Para realizar este proceso tiene que ingresar el dinero que existe en caja",
                            duration: 9000,
                            close: true,
                            gravity: "top",
                            position: "center",
                            backgroundColor: "linear-gradient(to left, rgb(254, 240, 138), rgb(253, 224, 71), rgb(250, 204, 21))",
                            stopOnFocus: true,
                        }).showToast();
                }else{

                  let datosAlpine = {
                      systemData:{
                          openingBalance   : this.openingBalance,
                          endowment        : this.endowment,         //dotación
                          saleCash         : this.saleCash,
                          saleCard         : this.saleCard,
                          withdrawal       : this.withdrawal,        //'retiro'
                          paymentvendor    : this.paymentvendor,     //proveedor de pagos
                          operationsBalance: this.operationsBalance
                      },

                      monedas: {
                          unoC   : this.unoC,
                          dosC   : this.dosC,
                          cincoC : this.cincoC,
                          diezC  : this.diezC,
                          veinteC: this.veinteC,
                          cincueC: this.cincueC,
                          unE    : this.unE,
                          dosE   : this.dosE
                      },
                      billetes: {
                          cincoE : this.cincoE,
                          diezE  : this.diezE,
                          veinteE: this.veinteE,
                          cincueE: this.cincueE,
                          cienE  : this.cienE,
                          doscE  : this.doscE
                      },
                      datafono:{
                          value: this.datafono
                      },
                      diferencia:{
                          value: this.diferenciaSistemaConConteoManual()
                      }
                  };
                  Livewire.dispatch('grabar-cierre-caja', { value: datosAlpine })

                }
            },
            closePanelBoxArching(data){
                    //console.log("closePanelBoxArching")
              if(data == 'panel') {     
                  this.showFormSalesFunctions = true;
                  this.panelSalesSummary      = true;
              }  
                    
              this.showPanelBoxArching      = false;
            },
            
    }))
})
