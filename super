    <script>

    document.addEventListener('alpine:init', () => {
        Alpine.data('vegetableFunctions', () => ({
            write: '', // resultado de lo digitado en el teclado

            titleVegetables: '',
            priceVegetables: '',
            weightProduct: "",
            titleWeight: "",
            // amountVegetable    : 0.00,
            formattedAmount: "",

            showFormProduct: false,
            // openModalVegetablesOLD: false,

            showProductsForCategory: true,

            toggleModalVegetables(id,title, price, urlImage) {

                this.showFormProduct = true
                this.showProductsForCategory = false;

                this.titleVegetables = title
                this.priceVegetables = price

                this.$wire.resetValidation()
                this.$wire.set('id', id)
                this.$wire.set('price', price)
                this.$wire.set('urlImage', urlImage)
            },
            calculateAmount(){
                this.weightProduct = this.write;

                this.$wire.set('newWeight', this.weightProduct)

                let priceVegetables = parseFloat(this.priceVegetables); // Convertir a número si es una cadena
                let weightProduct = parseFloat(this.weightProduct); // Convertir a número si es una cadena


                if (isNaN(priceVegetables) || isNaN(weightProduct)) {
                    this.formattedAmount = "";
                    this.titleWeight = "";
                    return;
                }

                let amountVegetable = priceVegetables * weightProduct;

                this.formattedAmount = amountVegetable.toLocaleString('es-ES', {
                    style: 'currency',
                    currency: 'EUR'
                });

                if(parseFloat(this.weightProduct)<1){
                    this.titleWeight = "Gr"
                }else{
                    this.titleWeight = "Kl"
                }

                this.focusTextInput();
            },
            focusTextInput() {
                const textInput = this.$refs.textInput;
                if (textInput) {
                    textInput.focus();
                }
            },

            closePanelForVegetable(){

                this.titleVegetables     = ''
                this.weightProduct     = ""
                this.priceVegetables     = ''
                this.titleWeight     = ""
                this.formattedAmount = ""
                this.write           = ""

                this.showPanelForVegetable   = false
                this.showFormProduct         = false
                this.showProductsForCategory = true


                this.showFormSalesFunctions = true;
            }
        }))
    })

</script>
