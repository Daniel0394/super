            calculateAmount(){
                this.weightProduct = this.write;

                this.$wire.set('newWeight', this.weightProduct)

                let priceFruits = parseFloat(this.priceFruits); // Convertir a número si es una cadena
                let weightProduct = parseFloat(this.weightProduct); // Convertir a número si es una cadena


                if (isNaN(priceFruits) || isNaN(weightProduct)) {
                    this.formattedAmount = "";
                    this.titleWeight = "";
                    return;
                }

                let amountFruit = priceFruits * weightProduct;

                this.formattedAmount = amountFruit.toLocaleString('es-ES', {
                    style: 'currency',
                    currency: 'EUR'
                });

                if(parseFloat(this.weightProduct)<1){
                    this.titleWeight = "Gr"
                }else{
                    this.titleWeight = "Kl"
                }

                this.focusTextInput();
            },
            focusTextInput() {
                const textInput = this.$refs.textInput;
                if (textInput) {
                    textInput.focus();
                }
            },

            closePanelForFruit(){

                this.titleFruits     = ''
                this.weightProduct     = ""
                this.priceFruits     = ''
                this.titleWeight     = ""
                this.formattedAmount = ""
                this.write           = ""

                this.showPanelForFruit   = false
                this.showFormProduct         = false
                this.showProductsForCategory = true


                this.showFormSalesFunctions = true;
            }
        }))
    })

</script>
