            // amountFruit    : 0.00,
            formattedAmount: "",

            showFormProduct: false,
            // openModalFruitsOLD: false,

            showProductsForCategory: true,

            toggleModalFruits(id,title, price, urlImage) {

                this.showFormProduct = true
                this.showProductsForCategory = false;

                this.titleFruits = title
