<script>
    document.addEventListener('alpine:init', () => {
        Alpine.data('virtualKeyboardFunctions', () => ({
            // write: '',  se lo pasa al contenedor
            shift: false,
            capslock: false,
            handleClick(event) {

                const deleteButton = event.target.closest('.delete');
                const checkButton = event.target.closest('.check');

                if (deleteButton) {
                    this.write = this.write.slice(0, -1);
                    this.calculateAmount();
                    return;
                }

                if (checkButton) {
                    let weightProduct = parseFloat(this.weightProduct);

                    if (isNaN(weightProduct)) {
                            Toastify({
                            text: "Ingrese el peso",
                            className: "info",
                            gravity: "top", // `top` or `bottom`
                            position: "center", // `left`, `center` or `right`
                            style: {
                                background: "linear-gradient(to left, rgb(254, 240, 138), rgb(253, 224, 71), rgb(250, 204, 21))",
                            }
                            }).showToast();
                        return;
                    }

                    this.$wire.savedByWeight()
                    return;
                }

                let character = event.target.innerText;

                if (event.target.classList.contains('left-shift') || event.target.classList.contains('right-shift')) {
                    document.querySelectorAll('.letter').forEach(letter => letter.classList.toggle('uppercase'));
                    document.querySelectorAll('.symbol span').forEach(span => span.classList.toggle('hidden'));

                    this.shift = !this.shift;
                    this.capslock = false;
                    this.focusTextInput();
                    return;
                }
                if (event.target.classList.contains('capslock')) {
                    document.querySelectorAll('.letter').forEach(letter => letter.classList.toggle('uppercase'));
                    this.capslock = !this.capslock;
                    this.focusTextInput();
                    return;
                }
                if (event.target.classList.contains('delete')) {
                    this.write = this.write.slice(0, -1);
                    this.focusTextInput();
                    return;
                }
                if (event.target.classList.contains('symbol')) {
                    const visibleSpan = event.target.querySelector('span:not(.hidden)');
                    character = visibleSpan ? visibleSpan.innerText : '';
                }
                if (event.target.classList.contains('space')) character = ' ';
                if (event.target.classList.contains('tab')) character = "\t";
                if (event.target.classList.contains('return')){
                    console.log("return")
                }

                if (event.target.classList.contains('uppercase')) character = character.toUpperCase();

                if (this.shift === true) {
                    document.querySelectorAll('.symbol span').forEach(span => span.classList.toggle('hidden'));
                    if (this.capslock === false) document.querySelectorAll('.letter').forEach(letter => letter.classList.toggle('uppercase'));
                    this.shift = false;
                    this.focusTextInput();
                    return;
                }

                this.write += character;

                this.calculateAmount();

            },

            focusTextInput() {
                const textInput = this.$refs.textInput;
                if (textInput) {
                    textInput.focus();
                }
            }
        }));
    });
</script>
